# Recipe Reborn - Environment Variables
# Copy this file to .env.local (local dev) and set these in Vercel for production.

# ===========================================
# AUTHENTICATION (REQUIRED)
# ===========================================
# JWT secret for signing tokens.
# Generate a strong one:  openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-string

# ===========================================
# DATABASE — Upstash Redis (REQUIRED)
# ===========================================
# Get these from https://console.upstash.com/redis (free tier is fine)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Alternative names (Vercel KV integration uses these)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ===========================================
# ANALYTICS (OPTIONAL)
# ===========================================
# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
# Get from https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console verification token (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ===========================================
# ENVIRONMENT
# ===========================================
NODE_ENV=development
