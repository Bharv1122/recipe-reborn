# Recipe Reborn - Environment Variables
# Copy this file to .env (local dev) and set these in Vercel for production.

# ===========================================
# DATABASE — Supabase Postgres via Prisma (REQUIRED)
# ===========================================
# Supabase dashboard → project → Connect:
#  - DATABASE_URL: "Transaction pooler" string (port 6543) + ?pgbouncer=true&connection_limit=1
#  - DIRECT_URL:   "Session pooler" string (port 5432) — used for migrations
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ===========================================
# AUTH — NextAuth (REQUIRED)
# ===========================================
# Local: http://localhost:3000  Production: https://recipereborn.com
NEXTAUTH_URL="http://localhost:3000"
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ===========================================
# AI — Gemini (REQUIRED for recipe generation)
# ===========================================
# Create a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# ===========================================
# PAYMENTS — Stripe (required in production)
# ===========================================
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PREMIUM_PRICE_ID=""
STRIPE_YEARLY_PRICE_ID=""
# Client-side twins (needed by app/pricing/page.tsx to build checkout requests)
NEXT_PUBLIC_STRIPE_PREMIUM_PRICE_ID=""
NEXT_PUBLIC_STRIPE_YEARLY_PRICE_ID=""

# ===========================================
# RATE LIMITING — Upstash Redis (optional; fails open without it)
# ===========================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ===========================================
# ANALYTICS (OPTIONAL)
# ===========================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""
